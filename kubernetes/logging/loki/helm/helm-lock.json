{
  "repo": {
    "name": "grafana-community",
    "url": "https://grafana-community.github.io/helm-charts"
  },
  "chart": {
    "name": "loki",
    "gitValuesPath": "https://raw.githubusercontent.com/grafana-community/helm-charts/refs/tags/{gitTag}/charts/loki/values.yaml",
    "gitTagFormat": "loki-{version}",
    "version": "6.55.0"
  },
  "releaseName": "loki",
  "valuesFile": "./values.yaml",
  "extraTemplateArgs": [
    "-n=logging",
    "--kube-version=1.31"
  ]
}
